{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "description": "Disable all requirements.txt updates by default",
      "matchManagers": ["pip_requirements", "pep621"],
      "enabled": false
    },
    {
      "description": "Re-enable specific packages ",
      "matchManagers": ["pip_requirements", "pep621"],
      "matchPackageNames": [
        "AMQPStorm",
        "amqpstorm-flask",
        "apscheduler",
        "Authlib",
        "certifi",
        "cffi",
        "charset-normalizer",
        "cryptography",
        "elody",
        "flask",
        "inuits-policy-based-auth",
        "PyJWT",
        "pytest",
        "requests",
        "requests-cache",
        "urllib3",
        "werkzeug"
      ],
      "enabled": true
    }
  ]
}
